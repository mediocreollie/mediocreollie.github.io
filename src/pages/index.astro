---
import BaseHead from '../components/BaseHead.astro';
import BlogList from '../components/BlogList.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getEntry, getCollection } from 'astro:content';

const homePage = await getEntry('pages', 'home');
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// CMS fields
const heroEyebrow = homePage?.data.heroEyebrow || '';
const heroTitle = homePage?.data.heroTitle || SITE_TITLE;
const heroSubtitle = homePage?.data.heroSubtitle || SITE_DESCRIPTION;

const primaryButtonText = homePage?.data.primaryButtonText || 'Explore';
const primaryButtonUrl = homePage?.data.primaryButtonUrl || '/blog';

const secondaryButtonText = homePage?.data.secondaryButtonText || 'Learn More';
const secondaryButtonUrl = homePage?.data.secondaryButtonUrl || '#';

const heroImage = homePage?.data.heroImage || '';

const heroImageMaxWidth = homePage?.data.heroImageMaxWidth || '500px';
const heroImageHeight = homePage?.data.heroImageHeight || '350px';
const heroImageObjectFit = homePage?.data.heroImageObjectFit || 'cover';
const heroImageColumnWidth = homePage?.data.heroImageColumnWidth || '45%';
const heroImageTranslateX = homePage?.data.heroImageTranslateX || '0px';

const mobileHeroImageMaxWidth = homePage?.data.mobileHeroImageMaxWidth || '100%';
const mobileHeroImageHeight = homePage?.data.mobileHeroImageHeight || '360px';
const mobileHeroImageObjectFit = homePage?.data.mobileHeroImageObjectFit || 'cover';
const mobileHeroImageTranslateX = homePage?.data.mobileHeroImageTranslateX || '0px';
const mobileHeroTextAlign = homePage?.data.mobileHeroTextAlign || 'left';
const mobileHeroTitleSize = homePage?.data.mobileHeroTitleSize || '3rem';
const mobileShowHeroImage = homePage?.data.mobileShowHeroImage ?? true;

const latestPostsTitle = homePage?.data.latestPostsTitle || 'Latest Posts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={heroTitle} description={heroSubtitle} />
    <style>
      body {
        font-family: Inter, sans-serif;
        background: #fdfdfd;
        color: #111;
      }

      main {
        width: 100%;
        max-width: 1500px;
        margin: 0 auto;
        padding: 0 3rem;
      }

      .container {
        max-width: 1500px;
        margin: 0 auto;
        padding: 0 3rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
        min-height: 75vh;
        text-align: var(--mobile-hero-text-align);
      }

      .hero-content {
        max-width: 550px;
      }

      h1 {
        font-size: var(--mobile-hero-title-size);
        margin-bottom: 1.5rem;
      }

      .description {
        color: #555;
        margin-bottom: 2rem;
      }

      .buttons {
        display: flex;
        gap: 1rem;
      }

      .btn {
        padding: 0.8rem 1.5rem;
        border-radius: 10px;
        text-decoration: none;
      }

      .btn-primary {
        background: black;
        color: white;
      }

      .btn-secondary {
        border: 1px solid black;
      }

      /* ✅ FIXED IMAGE SYSTEM */
      .hero-image {
        display: flex;
        width: 100%;
        justify-self: auto;
        justify-content: center;
        align-items: center;
      }

      .hero-image img {
        width: 100%;
        max-width: var(--mobile-hero-image-max-width);
        height: var(--mobile-hero-image-height);
        object-fit: var(--mobile-hero-image-object-fit);
        border-radius: 12px;
        transform: translateX(var(--mobile-hero-image-translate-x));
      }

      .hero-image.mobile-hide-on-mobile {
        display: none;
      }

      .latest-posts {
        margin-top: 5rem;
      }

      @media (min-width: 768px) {
        .hero {
          grid-template-columns: calc(100% - var(--hero-image-column-width)) var(--hero-image-column-width);
          text-align: left;
        }

        .hero-image {
          justify-self: end;
          justify-content: flex-end;
        }

        .hero-image.mobile-hide-on-mobile {
          display: block;
        }

        .hero-image img {
          max-width: var(--hero-image-max-width);
          height: var(--hero-image-height);
          object-fit: var(--hero-image-object-fit);
          transform: translateX(var(--hero-image-translate-x));
        }

        .hero-content h1 {
          font-size: 4rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <div class="container">
      <main>
        <section
          class="hero"
          style={`
            --hero-image-max-width: ${heroImageMaxWidth};
            --hero-image-height: ${heroImageHeight};
            --hero-image-object-fit: ${heroImageObjectFit};
            --hero-image-column-width: ${heroImageColumnWidth};
            --hero-image-translate-x: ${heroImageTranslateX};
            --mobile-hero-image-max-width: ${mobileHeroImageMaxWidth};
            --mobile-hero-image-height: ${mobileHeroImageHeight};
            --mobile-hero-image-object-fit: ${mobileHeroImageObjectFit};
            --mobile-hero-image-translate-x: ${mobileHeroImageTranslateX};
            --mobile-hero-text-align: ${mobileHeroTextAlign};
            --mobile-hero-title-size: ${mobileHeroTitleSize};
          `}
        >
          <div class="hero-content">
            {heroEyebrow && <p>{heroEyebrow}</p>}
            <h1 set:html={heroTitle} />
            <p class="description">{heroSubtitle}</p>

            <div class="buttons">
              <a href={primaryButtonUrl} class="btn btn-primary">{primaryButtonText}</a>
              <a href={secondaryButtonUrl} class="btn btn-secondary">{secondaryButtonText}</a>
            </div>
          </div>

          {heroImage && (
            <div class={"hero-image" + (mobileShowHeroImage ? '' : ' mobile-hide-on-mobile')}>
              <img src={heroImage} alt="Hero" />
            </div>
          )}
        </section>

        <section class="latest-posts">
          <h2>{latestPostsTitle}</h2>
          <BlogList posts={posts} />
        </section>
      </main>
    </div>

    <Footer />
  </body>
</html>