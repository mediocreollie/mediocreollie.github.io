---
import BaseHead from '../components/BaseHead.astro';
import BlogList from '../components/BlogList.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getEntry, getCollection } from 'astro:content';

const homePage = await getEntry('pages', 'home');
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const pageData = homePage?.data as Record<string, any> | undefined;
const heroEyebrow = pageData?.heroEyebrow || '';
const heroTitle = pageData?.heroTitle || SITE_TITLE;
const heroSubtitle = pageData?.heroSubtitle || SITE_DESCRIPTION;

const primaryButtonText = pageData?.primaryButtonText || 'Explore';
const primaryButtonUrl = pageData?.primaryButtonUrl || '/blog';

const secondaryButtonText = pageData?.secondaryButtonText || 'Learn More';
const secondaryButtonUrl = pageData?.secondaryButtonUrl || '#';

const heroImage = pageData?.heroImage || '';
const heroImageMaxWidth = pageData?.heroImageMaxWidth || '750px';
const heroImageHeight = pageData?.heroImageHeight || '525px';
const heroImageObjectFit = pageData?.heroImageObjectFit || 'cover';
const heroImageTranslateX = pageData?.heroImageTranslateX || '0px';

const mobileHeroImageMaxWidth = pageData?.mobileHeroImageMaxWidth || '100%';
const mobileHeroImageHeight = pageData?.mobileHeroImageHeight || '420px';
const mobileHeroImageObjectFit = pageData?.mobileHeroImageObjectFit || 'cover';
const mobileHeroImageTranslateX = pageData?.mobileHeroImageTranslateX || '0px';
const mobileShowHeroImage = pageData?.mobileShowHeroImage ?? true;
const latestPostsTitle = pageData?.latestPostsTitle || 'Latest Posts';
const featureCards = pageData?.featureCards || [];
const workItems = pageData?.workItems || [
  {
    title: 'Product rhythm for early-stage teams',
    description: 'Structured collaboration and storytelling that keeps decision-making calm, clear and forward-moving.',
    tag: 'Product',
  },
  {
    title: 'Audience-led editorial systems',
    description: 'Building simple publishing foundations for stories, launches and team narratives.',
    tag: 'Content',
  },
  {
    title: 'Designing warm digital experiences',
    description: 'Softly structured visual language for websites, tools and campaigns that feel human and intentional.',
    tag: 'Design',
  },
];

const heroImageClasses = `hero-image${mobileShowHeroImage ? '' : ' hero-image--hidden-mobile'}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={heroTitle} description={heroSubtitle} />
  </head>

  <body>
    <Header />

    <main>
      <section class="section section--tight">
        <div class="page-wrapper hero-grid">
          <article class="card hero-panel">
            {heroEyebrow && <p class="section-eyebrow">{heroEyebrow}</p>}
            <h1 set:html={heroTitle} />
            <p class="description">{heroSubtitle}</p>
            <div class="hero-actions">
              <a href={primaryButtonUrl} class="btn btn-primary">{primaryButtonText}</a>
              <a href={secondaryButtonUrl} class="btn btn-secondary">{secondaryButtonText}</a>
            </div>
          </article>

          {heroImage && (
            <div class={heroImageClasses} style={`--hero-image-max-width: ${heroImageMaxWidth}; --hero-image-height: ${heroImageHeight}; --hero-image-object-fit: ${heroImageObjectFit}; --hero-image-translate-x: ${heroImageTranslateX}; --mobile-hero-image-max-width: ${mobileHeroImageMaxWidth}; --mobile-hero-image-height: ${mobileHeroImageHeight}; --mobile-hero-image-object-fit: ${mobileHeroImageObjectFit}; --mobile-hero-image-translate-x: ${mobileHeroImageTranslateX};`}>
              <img src={heroImage} alt="Hero" />
            </div>
          )}
        </div>
      </section>

      <section class="section section--tight">
        <div class="page-wrapper">
          <div class="section-header">
            <p class="section-eyebrow">What I do</p>
            <h2 class="section-title">Helping teams and brands land more calm, usable work.</h2>
          </div>

          <div class="feature-grid">
            {featureCards.length > 0 ? (
              featureCards.map((card: any) => (
                <div class="card card--feature">
                  <p class="card__eyebrow">{card.title}</p>
                  <p class="card__copy">{card.description}</p>
                </div>
              ))
            ) : (
              <>
                <div class="card card--feature">
                  <p class="card__eyebrow">Creative strategy with commercial clarity</p>
                  <p class="card__copy">Bringing modern product and marketing thinking together, grounded in outcomes, audience insight and practical delivery.</p>
                </div>
                <div class="card card--feature">
                  <p class="card__eyebrow">Thoughtful operational delivery</p>
                  <p class="card__copy">Softly structured execution that keeps cross-functional teams aligned and business decisions moving forward.</p>
                </div>
                <div class="card card--feature">
                  <p class="card__eyebrow">AI-enabled, people-led work</p>
                  <p class="card__copy">Calm, practical AI adoption that improves processes and supports internal teams without adding noise.</p>
                </div>
              </>
            )}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="page-wrapper">
          <div class="section-header">
            <p class="section-eyebrow">Selected Work</p>
            <h2 class="section-title">A small set of recent projects and experiments.</h2>
          </div>

          <div class="work-grid">
            {workItems.map((work: any) => (
              <article class="card card--project">
                <p class="card__eyebrow">{work.tag}</p>
                <h3 class="card__title">{work.title}</h3>
                <p class="card__copy">{work.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--tight">
        <div class="page-wrapper">
          <div class="section-header section-header--split">
            <div>
              <p class="section-eyebrow">Writing</p>
              <h2 class="section-title">Recent thinking from the blog.</h2>
            </div>
            <a href="/blog" class="btn btn-secondary">Read all posts</a>
          </div>

          <div class="writing-preview">
            <BlogList posts={posts} showImage={false} showDescription={true} />
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
