---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getEntry, render } from 'astro:content';

const homePage = await getEntry('pages', 'home');
const { Content } = await render(homePage!);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={homePage?.data.title || SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{homePage?.data.title || SITE_TITLE}</h1>
			{homePage?.data.intro && <p>{homePage.data.intro}</p>}
			<Content />
		</main>
		<Footer />
	</body>
</html>
