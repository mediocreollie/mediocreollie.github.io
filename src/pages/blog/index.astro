---
import BaseHead from '../../components/BaseHead.astro';
import BlogList from '../../components/BlogList.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection, getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const blogListingTitle = settings?.data.blogListingTitle || 'Blog';
const blogListingIntro = settings?.data.blogListingIntro || '';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={blogListingTitle} description={blogListingIntro} />
		<style>
			.blog-page {
				width: min(100%, 1040px);
				margin: 0 auto;
				padding-inline: 1.5rem;
			}

			.blog-header {
				margin-bottom: 1.75rem;
				max-width: 100%;
			}

			.blog-header h1 {
				margin-bottom: 0.75rem;
			}

			.blog-header p {
				color: rgb(var(--muted));
				font-size: 1.05rem;
				line-height: 1.7;
				max-width: 760px;
				margin: 0;
			}

			.blog-posts {
				width: 100%;
			}

			.blog-posts > ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-page">
				{blogListingTitle && (
					<section class="blog-header">
						<h1>{blogListingTitle}</h1>
						{blogListingIntro && <p>{blogListingIntro}</p>}
					</section>
				)}
				<section class="blog-posts">
					<BlogList posts={posts} />
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
