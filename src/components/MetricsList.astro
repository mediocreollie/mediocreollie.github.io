---
const { metrics } = Astro.props;
const hasMetrics = Array.isArray(metrics) && metrics.length > 0;
---
{hasMetrics && (
	<div class="metrics-list">
		{metrics.map((metric) => (
			<div class="metric-item">
				{metric.value && <div class="metric-value">{metric.value}</div>}
				{metric.label && <div class="metric-label">{metric.label}</div>}
			</div>
		))}
	</div>
)}

<style>
	.metrics-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 0.85rem;
		margin-top: 1.5rem;
	}

	.metric-item {
		padding: 1rem;
		border-radius: 18px;
		background: rgba(var(--surface), 0.95);
		border: 1px solid rgba(var(--border), 0.7);
	}

	.metric-value {
		font-size: 1.1rem;
		font-weight: 700;
		color: rgb(var(--text));
		margin-bottom: 0.35rem;
	}

	.metric-label {
		font-size: 0.95rem;
		color: rgb(var(--muted));
		line-height: 1.6;
	}
</style>
