---
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: any[];
  showImage?: boolean;
  showDescription?: boolean;
}

const {
  posts,
  showImage = true,
  showDescription = true,
} = Astro.props;
---

<ul class="post-list">
  {posts.map((post) => (
    <li class="post-card">
      {showImage && post.data.heroImage ? (
        <div class="post-card-image">
          <img src={post.data.heroImage} alt={post.data.title} />
        </div>
      ) : null}

      <div class="post-card-content">
        <a href={`/blog/${post.slug}`}>
          <h2>{post.data.title}</h2>
        </a>
        <p class="date"><FormattedDate date={post.data.pubDate} /></p>
        {showDescription && post.data.description ? (
          <p class="description">{post.data.description}</p>
        ) : null}
      </div>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    background: white;
  }

  .post-card-image {
    flex: 0 0 120px;
    width: 120px;
    height: 80px;
    overflow: hidden;
    border-radius: 12px;
    background: #f5f5f5;
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-card-content {
    flex: 1;
    min-width: 0;
  }

  .post-card-content a {
    color: inherit;
    text-decoration: none;
  }

  .post-card-content h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .date {
    margin: 0.35rem 0 0;
    color: #666;
    font-size: 0.9rem;
  }

  .description {
    margin: 0.85rem 0 0;
    color: #444;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .post-card {
      flex-direction: column;
    }

    .post-card-image {
      width: 100%;
      height: 200px;
    }
  }
</style>