---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: any[];
  showImage?: boolean;
  showDescription?: boolean;
}

const {
  posts,
  showImage = true,
  showDescription = true,
} = Astro.props;

const MAX_PREVIEW_LENGTH = 150;

function normalizePreviewText(source: string) {
  return source
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .replace(/`+([^`]+)`+/g, '$1')
    .replace(/#+/g, '')
    .replace(/>\s?/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function getPreviewText(post: any) {
  const source =
    post.data.description ||
    (typeof post.body === 'string'
      ? post.body
      : post.body?.raw ?? '') ||
    '';

  const text = normalizePreviewText(source);
  if (!text) return '';
  if (text.length <= MAX_PREVIEW_LENGTH) return text;

  const truncated = text.slice(0, MAX_PREVIEW_LENGTH);
  const lastSpace = truncated.lastIndexOf(' ');
  return `${truncated.slice(0, lastSpace > 0 ? lastSpace : MAX_PREVIEW_LENGTH)}…`;
}
---

<ul class="post-list">
  {posts.map((post) => {
    const preview = showDescription ? getPreviewText(post) : '';
    return (
      <li class="post-card card card--writing">
        <a class="post-card-link" href={`/blog/${post.id}`} aria-label={`Read ${post.data.title}`}>
          {showImage && post.data.heroImage ? (
            <div class="post-card-image">
              <Image
                src={post.data.heroImage}
                alt={post.data.title}
                width={120}
                height={80}
              />
            </div>
          ) : null}

          <div class="post-card-content">
            <h2>{post.data.title}</h2>
            <p class="date"><FormattedDate date={post.data.pubDate} /></p>
            {preview ? <p class="description">{preview}</p> : null}
          </div>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.9rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin: 0;
    padding: 0.95rem;
    border: 1px solid rgba(var(--border), 0.75);
    border-radius: 24px;
    background: rgba(var(--surface), 0.98);
    box-shadow: var(--box-shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 26px 58px rgba(34, 41, 57, 0.09);
  }

  .post-card-image {
    width: 100%;
    min-height: 100px;
    overflow: hidden;
    border-radius: 18px;
    background: rgba(var(--surface-alt), 0.9);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-card-link {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    width: 100%;
    color: inherit;
    text-decoration: none;
  }

  .post-card-content {
    flex: 1;
    min-width: 0;
  }

  .post-card-content h2 {
    margin: 0;
    font-size: 1.05rem;
    color: rgb(var(--text));
    line-height: 1.2;
  }

  .date {
    margin: 0.2rem 0 0;
    color: rgb(var(--muted));
    font-size: 0.9rem;
  }

  .description {
    margin: 0.5rem 0 0;
    color: rgb(var(--muted));
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-height: 3rem;
  }

  @media (min-width: 768px) {
    .post-card {
      flex-direction: row;
      align-items: flex-start;
    }

    .post-card-link {
      flex-direction: row;
      align-items: flex-start;
    }

    .post-card-image {
      flex: 0 0 120px;
      width: 120px;
      height: 90px;
    }
  }
</style>
