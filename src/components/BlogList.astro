---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: any[];
  showImage?: boolean;
  showDescription?: boolean;
}

const {
  posts,
  showImage = true,
  showDescription = true,
} = Astro.props;
---

<ul class="post-list">
  {posts.map((post) => (
    <li class="post-card card card--writing">
      <a class="post-card-link" href={`/blog/${post.id}`} aria-label={`Read ${post.data.title}`}>
        {showImage && post.data.heroImage ? (
          <div class="post-card-image">
            <Image
              src={post.data.heroImage}
              alt={post.data.title}
              width={120}
              height={80}
            />
          </div>
        ) : null}

        <div class="post-card-content">
          <h2>{post.data.title}</h2>
          <p class="date"><FormattedDate date={post.data.pubDate} /></p>
          {showDescription && post.data.description ? (
            <p class="description">{post.data.description}</p>
          ) : null}
        </div>
      </a>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(var(--border), 0.75);
    border-radius: 24px;
    background: rgba(var(--surface), 0.98);
    box-shadow: var(--box-shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 26px 58px rgba(34, 41, 57, 0.09);
  }

  .post-card-image {
    width: 100%;
    min-height: 120px;
    overflow: hidden;
    border-radius: 18px;
    background: rgba(var(--surface-alt), 0.9);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-card-link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    color: inherit;
    text-decoration: none;
  }

  .post-card-content {
    flex: 1;
    min-width: 0;
  }

  .post-card-content h2 {
    margin: 0;
    font-size: 1.1rem;
    color: rgb(var(--text));
  }

  .date {
    margin: 0.25rem 0 0;
    color: rgb(var(--muted));
    font-size: 0.9rem;
  }

  .description {
    margin: 0.75rem 0 0;
    color: rgb(var(--muted));
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .post-card {
      flex-direction: row;
      align-items: center;
    }

    .post-card-link {
      flex-direction: row;
      align-items: center;
    }

    .post-card-image {
      flex: 0 0 130px;
      width: 130px;
      height: 90px;
    }
  }
</style>
