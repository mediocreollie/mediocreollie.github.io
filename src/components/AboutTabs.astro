---
import { getEntry } from 'astro:content';

const about = await getEntry('pages', 'about');
const data = about?.data || {};
const intro = data.intro || data.tabsIntro || '';
const metrics = data.metrics || [];
const tabs = data.tabs || [];
const defaultTabs = ['All', 'Marketing', 'Operations', 'Product', 'AI', 'Commercial'];
---

<div class="about-tabs-container">
	{intro && (
		<div class="intro-block">
			<p>{intro}</p>
		</div>
	)}

	{metrics.length > 0 && (
		<div class="metrics-row" role="list">
			{metrics.map((m) => (
				<div class="metric-card" role="listitem">
					<div class="metric-value">{m.value}</div>
					<div class="metric-label">{m.label}</div>
				</div>
			))}
		</div>
	)}

	<div class="tabs-nav">
		{(tabs.length > 0 ? tabs : defaultTabs.map((t) => ({ label: t }))).map((t, i) => (
			<button class={i === 0 ? 'tab-button active' : 'tab-button'} data-tab={t.label.toLowerCase().replace(/\s+/g, '-')}>{t.label}</button>
		))}
	</div>

	<div class="tabs-content">
		{(tabs.length > 0 ? tabs : defaultTabs.map((t) => ({ label: t, heading: t }))).map((t, i) => {
			const id = t.label.toLowerCase().replace(/\s+/g, '-');
			return (
				<div class={i === 0 ? 'tab-pane active' : 'tab-pane'} id={id}>
					{t.heading && <h3>{t.heading}</h3>}
					{t.intro && <p>{t.intro}</p>}
					{t.body && <p>{t.body}</p>}
					{t.bullets && t.bullets.length > 0 && (
						<ul>
							{t.bullets.map((b) => <li>{b}</li>)}
						</ul>
					)}
					{t.relatedProjects && t.relatedProjects.length > 0 && (
						<div class="related-projects">
							<h4>Related projects</h4>
							<ul>
								{t.relatedProjects.map((p) => (
									<li><a href={p.url}>{p.title}</a></li>
								))}
							</ul>
						</div>
					)}
				</div>
			);
		})}
	</div>
</div>

<style>
	.about-tabs-container {
		width: 100%;
		max-width: 740px;
		margin: auto;
		padding: 2rem;
		border-radius: 32px;
		background: rgba(var(--surface-alt), 0.96);
		border: 1px solid rgba(var(--border), 0.85);
		box-shadow: var(--box-shadow);
	}

	.intro-block p {
		margin: 0 0 1.5rem;
		font-size: 1.05rem;
		line-height: 1.8;
		color: rgb(var(--text));
	}

	.metrics-row {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1.75rem;
	}

	.metric-card {
		padding: 1rem;
		border-radius: 20px;
		background: rgba(var(--surface), 0.98);
		border: 1px solid rgba(var(--border), 0.75);
	}

	.metric-value {
		font-size: 1.2rem;
		font-weight: 700;
		color: rgb(var(--text));
		margin-bottom: 0.25rem;
	}

	.metric-label {
		font-size: 0.95rem;
		color: rgb(var(--muted));
		line-height: 1.6;
	}

	.tabs-nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
		gap: 0.75rem;
		margin-bottom: 1.75rem;
	}

	.tab-button {
		padding: 0.95rem 1rem;
		border: 1px solid rgba(var(--border), 0.75);
		background: rgba(var(--surface), 0.98);
		color: rgb(var(--text));
		cursor: pointer;
		font-size: 0.95rem;
		font-weight: 600;
		border-radius: 18px;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.tab-button:hover {
		background: rgba(var(--accent), 0.08);
	}

	.tab-button.active {
		color: rgb(var(--accent));
		border-color: rgba(var(--accent), 0.45);
		background: rgba(var(--accent), 0.1);
		font-weight: 700;
	}

	.tabs-content {
		min-height: 240px;
	}

	.tab-pane {
		display: none;
		animation: fadeIn 0.3s ease;
	}

	.tab-pane.active {
		display: block;
	}

	.tab-pane h3 {
		margin-top: 0;
		color: rgb(var(--accent));
		font-size: 1.4rem;
	}

	.tab-pane p {
		margin: 1rem 0;
		line-height: 1.75;
		color: rgb(var(--muted));
	}

	.tab-pane strong {
		color: rgb(var(--text));
		font-weight: 700;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@media (max-width: 680px) {
		.about-tabs-container {
			padding: 1.5rem;
		}

		.metrics-row {
			grid-template-columns: 1fr;
		}

		.tab-button {
			font-size: 0.92rem;
			padding: 0.85rem 0.9rem;
		}

		.tab-pane h3 {
			font-size: 1.25rem;
		}
	}
</style>

<script>
	// Minimal tab interaction: delegate clicks and toggle active classes
	document.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement).closest && (e.target as HTMLElement).closest('.tab-button');
		if (!btn) return;
		const tabName = btn.getAttribute('data-tab');
		if (!tabName) return;
		const container = btn.closest('.about-tabs-container');
		if (!container) return;
		const buttons = container.querySelectorAll('.tab-button');
		const panes = container.querySelectorAll('.tab-pane');

		buttons.forEach((b) => b.classList.remove('active'));
		panes.forEach((p) => p.classList.remove('active'));

		btn.classList.add('active');
		const pane = container.querySelector('#' + tabName);
		if (pane) pane.classList.add('active');
	});
</script>
